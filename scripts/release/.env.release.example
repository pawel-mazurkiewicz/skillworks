# Skillworks release credentials
# Copy this file to .env.release at the repo root and fill in the values.
# .env.release is gitignored and must NEVER be committed.

# ── macOS signing + notarization ─────────────────────────────────────────────
# Only needed on your Mac. Leave blank on Windows / Linux machines.
#
# Step-by-step:
#   1. Xcode → Settings → Accounts → your Apple ID → Manage Certificates
#   2. Right-click "Developer ID Application" → Export Certificate → save as cert.p12
#   3. base64 -i cert.p12 | pbcopy   →   paste the result below
#   4. Delete cert.p12 from disk once done
APPLE_CERTIFICATE=

#   The password you set when exporting the .p12
APPLE_CERTIFICATE_PASSWORD=

#   Exact string shown in Keychain Access / Xcode, parenthetical Team ID included:
#   "Developer ID Application: Your Name (XXXXXXXXXX)"
APPLE_SIGNING_IDENTITY=

#   Your Apple ID email
APPLE_ID=

#   App-specific password — generate at appleid.apple.com
#   Sign-In & Security → App-Specific Passwords → label it "Skillworks notarization"
APPLE_PASSWORD=

#   10-character Team ID from developer.apple.com/account (shown top-right)
APPLE_TEAM_ID=

# ── Tauri updater signing (all platforms) ────────────────────────────────────
# Generate ONCE with:
#   npx tauri signer generate -w ~/.tauri/skillworks.key
# Then paste the contents of ~/.tauri/skillworks.key below.
# Put the matching public key in tauri.conf.json → plugins.updater.pubkey
TAURI_SIGNING_PRIVATE_KEY=

# Password chosen during key generation. Leave blank if you pressed Enter (no password).
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained personal access token with Contents: read+write, Metadata: read
# Generate at: github.com/settings/tokens
GITHUB_TOKEN=

GITHUB_REPO=pawel-mazurkiewicz/skillworks
