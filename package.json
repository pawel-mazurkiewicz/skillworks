{
  "name": "skillworks",
  "version": "0.1.0",
  "description": "Project-aware skill workspace for local coding agents.",
  "type": "commonjs",
  "bin": {
    "skillworks": "src/mcp-server.js",
    "skillworks-mcp": "src/mcp-server.js",
    "agent-skill-manager": "src/mcp-server.js",
    "agent-skill-manager-mcp": "src/mcp-server.js"
  },
  "files": [
    "src",
    "public",
    "assets",
    "scripts",
    "src-tauri",
    "README.md"
  ],
  "scripts": {
    "start": "node src/server.js",
    "mcp": "node src/mcp-server.js",
    "static": "node src/server.js --host 127.0.0.1 --port 5179",
    "dev": "node scripts/vite-dev.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "desktop:dev": "tauri dev",
    "desktop:sidecar": "node scripts/build-tauri-sidecar.js",
    "desktop:build": "tauri build",
    "test": "node --test"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "@tauri-apps/cli": "^2.0.0",
    "@yao-pkg/pkg": "^6.0.0",
    "vite": "^7.0.0"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "assets/**/*"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@uiw/react-codemirror": "^4.25.9",
    "dompurify": "^3.4.3",
    "marked": "^18.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
